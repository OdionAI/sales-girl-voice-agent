LIVEKIT_URL=wss://livekit-staging.example.com
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

DEEPGRAM_API_KEY=your_deepgram_api_key
GOOGLE_API_KEY=your_google_api_key
GOOGLE_LLM_MODEL_DEFAULT=gemini-2.0-flash
GOOGLE_LLM_MODEL_EN=gemini-2.0-flash
GOOGLE_LLM_MODEL_FR=gemini-2.0-flash

# Appointments backend service used by tool calls
APPOINTMENTS_API_BASE_URL=http://localhost:8080
APPOINTMENTS_API_TIMEOUT_SECONDS=8

# Agent config backend
AGENT_CONFIG_API_BASE_URL=http://localhost:8092
AGENT_CONFIG_API_TIMEOUT_SECONDS=8

# Knowledge base backend
KNOWLEDGE_SERVICE_BASE_URL=http://localhost:8095
KNOWLEDGE_SERVICE_TOKEN=local-internal-service-token
KNOWLEDGE_SERVICE_TIMEOUT_SECONDS=8

# Multi-tenant metadata tags for tracing headers
AGENT_CLIENT_ID=sales-girl-internal

# Optional Langfuse tracing for agent tool calls
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Conversation persistence (recommended: required mode)
CONVERSATION_API_BASE_URL=http://localhost:8091
CONVERSATION_SERVICE_TOKEN=local-internal-service-token
CONVERSATION_BUSINESS_ID=
CONVERSATION_API_TIMEOUT_SECONDS=8
CONVERSATION_SERVICE_REQUIRED=true
# When CONVERSATION_API_BASE_URL is set, create_ticket POSTs here so tickets appear on the dashboard.
# If unset, internal tickets prefer HOTEL_OPS_SERVICE_BASE_URL (often conversation-service in prod)
# before OPS_SERVICE_BASE_URL so generic agents do not POST dashboard-shaped bodies to demo CRM.

# Demo CRM tool backend
OPS_SERVICE_BASE_URL=http://localhost:8095
OPS_SERVICE_TOKEN=local-internal-service-token

# Hotel internal platform ops backend
HOTEL_OPS_SERVICE_BASE_URL=

# Require verified phone identity before starting a call
REQUIRE_VERIFIED_PHONE=true

# Enable the French runtime only when the worker processes are isolated enough
# to avoid LiveKit worker HTTP-port conflicts on the same host.
ENABLE_FRENCH_AGENT=false

# Odion TTS consistency defaults for English sessions
ENABLE_ODION_TTS_EN=true
ENABLE_ODION_TTS_FR=true
ODION_TTS_BASE_URL=https://eu-tts.odion.ai
ODION_TTS_EXPERIMENT_OWNER_ID=mavinomichael@gmail.com
ODION_TTS_EXPERIMENT_VOICE_ID=d270a5cec6914373b9deed1d1c3cbade
ODION_TTS_EXPERIMENT_LANGUAGE_HINT=English
ODION_TTS_EXPERIMENT_SEED=0
STRICT_ODION_CLONE_CONSISTENCY=true

# Turn-taking tuning
# Lower endpointing delays to respond faster after user pauses.
# Increase interruption duration to reduce accidental barge-ins.
TURN_MIN_ENDPOINTING_DELAY=0.45
TURN_MAX_ENDPOINTING_DELAY=1.2
TURN_MIN_INTERRUPTION_DURATION=0.7

# LiveKit recording (required for real conversation audio capture)
LIVEKIT_RECORDING_ENABLED=false
LIVEKIT_RECORDING_GCS_BUCKET=
LIVEKIT_RECORDING_GCP_CREDENTIALS_JSON=
LIVEKIT_RECORDING_FILE_PREFIX=livekit-recordings
LIVEKIT_RECORDING_FORMAT=mp3
LIVEKIT_RECORDING_PUBLIC_BASE_URL=
LIVEKIT_RECORDING_POLL_TIMEOUT_SECONDS=45
LIVEKIT_RECORDING_POLL_INTERVAL_SECONDS=2
